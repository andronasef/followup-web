# Copy to .env.local for local dev (docker compose up -d db first).
# Never commit real values — see .claude/CLAUDE.md "Secrets" constraint.

# Postgres connection string. Matches docker-compose.yml's postgres service
# for local dev (host port 5433 — avoids colliding with any other local
# Postgres on 5432); Coolify supplies the production value as a runtime-only
# var instead.
DATABASE_URL=postgres://onechat:onechat@localhost:5433/onechat

# >=32 random bytes, used to sign both the visitor identity cookie and the
# owner session cookie (jose HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# One-time token required to POST /api/admin/setup (D-14). Discard/rotate
# after the owner account is created — the route self-disables regardless.
SETUP_TOKEN=

# HMAC-SHA256 key used to hash the sender's IP for OPS-01 rate limiting
# (T-01-25) — the raw IP is never stored or logged, only this hash. Rotate
# independently of SESSION_SECRET whenever convenient. Optional: if unset,
# src/app/api/chat/messages/route.ts falls back to SESSION_SECRET so the
# route still works without a second mandatory secret — set a dedicated
# value here for production. Generate the same way as SESSION_SECRET.
IP_HASH_SECRET=

# OVHcloud AI Endpoints (OpenAI-compatible) — translation provider.
OVH_API_KEY=
OVH_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1

# NVIDIA NIM (OpenAI-compatible) — spike-time translation provider substitution
# for OVHcloud AI Endpoints, per owner instruction (see 01-02-SUMMARY.md "Decisions").
# OVH above remains the documented default provider; this is the active
# provider selected via TRANSLATION_PROVIDER until further notice.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=qwen/qwen3.5-397b-a17b

# Which TranslationProvider entry is active: "ovh" or "nvidia" (see
# src/server/config/models.ts). Defaults to nvidia per the Plan 01-02 spike.
TRANSLATION_PROVIDER=nvidia

# web-push VAPID keypair (D-01/D-02/D-03) -- the owner generates this
# keypair themselves, OFF-BOX, via `npx web-push generate-vapid-keys` run
# on their own machine, NEVER inside this repo's Docker build. Losing the
# private key makes every existing visitor permanently unreachable -- the
# single unrecoverable event in this system. Back it up in a second
# location independent of the deployment platform.
#
# Build-time vs runtime split (CLAUDE.md): VAPID_PRIVATE_KEY is
# runtime-only (never a build ARG/image layer). NEXT_PUBLIC_VAPID_PUBLIC_KEY
# is build-time (the client bundle inlines it) and must always equal
# VAPID_PUBLIC_KEY -- changing either requires a rebuild, not just a
# restart.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@example.org
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
