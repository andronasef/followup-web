# Copy to .env.local for local dev (docker compose up -d db first).
# Never commit real values — see .claude/CLAUDE.md "Secrets" constraint.

# Postgres connection string. Matches docker-compose.yml's postgres service
# for local dev (host port 5433 — avoids colliding with any other local
# Postgres on 5432); Coolify supplies the production value as a runtime-only
# var instead.
DATABASE_URL=postgres://onechat:onechat@localhost:5433/onechat

# >=32 random bytes, used to sign both the visitor identity cookie and the
# owner session cookie (jose HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# One-time token required to POST /api/admin/setup (D-14). Discard/rotate
# after the owner account is created — the route self-disables regardless.
SETUP_TOKEN=

# OVHcloud AI Endpoints (OpenAI-compatible) — translation provider.
OVH_API_KEY=
OVH_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1

# NVIDIA NIM (OpenAI-compatible) — spike-time translation provider substitution
# for OVHcloud AI Endpoints, per owner instruction (see 01-02-SUMMARY.md "Decisions").
# OVH above remains the documented default provider; this is the active
# provider selected via TRANSLATION_PROVIDER until further notice.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=qwen/qwen3.5-397b-a17b

# Which TranslationProvider entry is active: "ovh" or "nvidia" (see
# src/server/config/models.ts). Defaults to nvidia per the Plan 01-02 spike.
TRANSLATION_PROVIDER=nvidia
